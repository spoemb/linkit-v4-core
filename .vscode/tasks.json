{
    "version": "2.0.0",
    // =========================================================================
    // Build Tools Configuration
    // =========================================================================
    // IMPORTANT: Update the PATH below if your toolchain is installed elsewhere
    // This setting must match the PATH in scripts/build_core.sh (line 16)
    //
    // Required tools:
    //   - ARM GCC Toolchain (arm-none-eabi-gcc)
    //   - nrfutil (Nordic utility tool)
    // =========================================================================
    "options": {
        "env": {
            "PATH": "/home/schade/tools/gcc-arm-none-eabi-10.3-2021.10/bin:/home/schade/.nrfutil/bin:${env:PATH}"
        }
    },
    "tasks": [
		// =====================================================================
		// LINKIT Board Tasks
		// =====================================================================
		{
			"type": "shell",
			"label": "LINKIT: build",
			"command": "./scripts/build_core.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "LINKIT: clean build",
			"command": "rm -rf ports/nrf52840/build/CORE && ./scripts/build_core.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "LINKIT: flash",
			"command": "nrfjprog --recover && nrfjprog -f nrf52 --program ports/nrf52840/build/CORE/LinkIt_CORE_board_merged-*.hex --sectorerase && nrfjprog -f nrf52 --reset",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		// =====================================================================
		// LinkIt V4 SMD Board Tasks
		// =====================================================================
		{
			"type": "shell",
			"label": "LinkItV4-SMD: clean build (Debug)",
			"command": "rm -rf ports/nrf52840/build/LINKIT_SMD && mkdir -p ports/nrf52840/build/LINKIT_SMD && cd ports/nrf52840/build/LINKIT_SMD && cmake -DCMAKE_TOOLCHAIN_FILE=../../toolchain_arm_gcc_nrf52.cmake -DDEBUG_LEVEL=4 -DBOARD=LINKIT -DCMAKE_BUILD_TYPE=Debug -DMODEL=UW -DARGOS_SMD=ON -DENABLE_AXL_SENSOR=ON ../.. && make -j20",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "LinkItV4-SMD: flash (Debug)",
			"detail": "Flash Debug build with SoftDevice (no bootloader)",
			"command": "nrfjprog --recover && nrfjprog -f nrf52 --program ports/nrf52840/drivers/nRF5_SDK_17.0.2/components/softdevice/s140/hex/s140_nrf52_7.2.0_softdevice.hex --sectorerase && nrfjprog -f nrf52 --program ports/nrf52840/build/LINKIT_SMD/LinkIt_UW_board.hex --sectorerase && nrfjprog -f nrf52 --reset",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
