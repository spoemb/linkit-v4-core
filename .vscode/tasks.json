			"type": "shell",
			"label": "RSPB: build (Debug)",
			"command": "mkdir -p ports/nrf52840/build/RSPB && cd ports/nrf52840/build/RSPB && cmake -DCMAKE_TOOLCHAIN_FILE=../../toolchain_arm_gcc_nrf52.cmake -DDEBUG_LEVEL=4 -DBOARD=RSPB -DCMAKE_BUILD_TYPE=Debug -DMODEL=CORE -DARGOS_SMD=ON -DENABLE_PRESSURE_SENSOR=ON -DENABLE_AXL_SENSOR=ON -DGPS_FAKE_POSITION=0 ../.. && make -j20",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
