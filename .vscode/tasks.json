{
    "version": "2.0.0",
    // =========================================================================
    // Build Tools Configuration
    // =========================================================================
    // IMPORTANT: Update the PATH below if your toolchain is installed elsewhere
    // This setting must match the PATH in scripts/build_core.sh (line 16)
    //
    // Required tools:
    //   - ARM GCC Toolchain (arm-none-eabi-gcc)
    //   - nrfutil (Nordic utility tool)
    // =========================================================================
    "options": {
        "env": {
            "PATH": "/home/schade/tools/gcc-arm-none-eabi-10-2020-q4-major/bin:/home/schade/.nrfutil/bin:${env:PATH}"
        }
    },
    "tasks": [
		{
			"type": "shell",
			"label": "Bootloader: build",
			"command": "make mergehex",
			"args": [],
			"options": {
			"cwd": "${workspaceFolder}/ports/nrf52840/bootloader/gentracker_secure_bootloader/gentracker_v1.0/armgcc"
			},	
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Bootloader: clean build",
			"command": "rm -rf ${workspaceFolder}/ports/nrf52840/bootloader/gentracker_secure_bootloader/gentracker_v1.0/armgcc/_build && make mergehex",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}/ports/nrf52840/bootloader/gentracker_secure_bootloader/gentracker_v1.0/armgcc"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Core: build",
			"command": "./scripts/build_core.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Core: clean build",
			"command": "rm -rf ports/nrf52840/build/CORE && ./scripts/build_core.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Bootloader: flash",
			"command": "nrfjprog --recover && nrfjprog -f nrf52 --program ports/nrf52840/bootloader/gentracker_secure_bootloader/gentracker_v1.0/armgcc/_build/cls_bootloader_v1_linkit_merged.hex --sectoranduicrerase && nrfjprog -f nrf52 --reset",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Core: flash",
			"command": "nrfjprog --recover && nrfjprog -f nrf52 --program ports/nrf52840/build/CORE/LinkIt_CORE_board_merged-*.hex --sectorerase && nrfjprog -f nrf52 --reset",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Unit Tests: compile",
			"command": "./scripts/build_unit_tests.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Unit Tests: compile (clean)",
			"command": "rm -rf tests/build && ./scripts/build_unit_tests.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
		{
			"type": "shell",
			"label": "Unit Tests: run",
			"command": "cd tests/build && ln -sf ../data . && ./CLSGenTrackerTests -ojunit",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
		},
    ],
  }